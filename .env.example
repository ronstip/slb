# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# BigQuery
BQ_DATASET=social_listening

# GCS Buckets (default: {project_id}-media, {project_id}-exports)
GCS_MEDIA_BUCKET=your-gcp-project-id-media
GCS_EXPORTS_BUCKET=your-gcp-project-id-exports

# Cloud Tasks
CLOUD_TASKS_QUEUE=worker-queue

# Gemini Models
GEMINI_MODEL=gemini-2.5-flash
ENRICHMENT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-005

# Vetric API (per-platform keys) - fallback vendor for X/Twitter, primary for Instagram
VETRIC_API_KEY_TWITTER=your-twitter-api-key
VETRIC_API_KEY_INSTAGRAM=your-instagram-api-key
VETRIC_API_KEY_TIKTOK=your-tiktok-api-key
VETRIC_API_KEY_REDDIT=
VETRIC_API_KEY_YOUTUBE=

# X (Twitter) API v2 - OAuth 2.0 App-Only Bearer Token. Default vendor for `twitter`.
X_API_BEARER_TOKEN=
# When true, quoted/replied source tweets hydrated in `includes.tweets` are
# promoted to first-class Posts in the same Batch. Parents wait for the dep's
# media to download, then enrich with the source's text+media as context.
# Default false (no behavior change). Flip per environment to roll out.
X_API_UNPACK_REFERENCED_POSTS=false

# Apify - primary vendor for Instagram, Facebook, TikTok (pay-per-result)
APIFY_API_TOKEN=
APIFY_ACTOR_INSTAGRAM=apify/instagram-scraper
APIFY_ACTOR_FACEBOOK=scrapeforge/facebook-search-posts
APIFY_ACTOR_FACEBOOK_PAGE=apify/facebook-posts-scraper
APIFY_ACTOR_FACEBOOK_GROUP=apify/facebook-groups-scraper
APIFY_ACTOR_TIKTOK=clockworks/tiktok-scraper
APIFY_RUN_TIMEOUT_SEC=1500
APIFY_MAX_RUNS_PER_COLLECTION=30
APIFY_MAX_PARALLEL_RUNS=3
APIFY_MEMORY_MBYTES=2048
APIFY_BUILD=
APIFY_PROXY_GROUP=RESIDENTIAL

# HikerAPI - Instagram private-API provider; default for IG KEYWORD collection
# (reels SERP reaches viral content the hashtag surfaces can't). Channel + all
# URL-based work (engagement refresh, direct post-by-URL fetch) stay on Apify.
# If unset, IG keyword collection gracefully falls back to Apify.
HIKERAPI_API_KEY=
# Anti-runaway BACKSTOP only (not the normal stop). Pagination is request-driven:
# it stops when the requested post count is reached, the SERP runs dry, or it
# saturates (pages stop adding new posts). The effective ceiling scales with the
# requested count, so this just acts as a floor for untargeted collects. Safe to
# leave at the default or remove the line entirely.
HIKERAPI_MAX_PAGES_PER_KEYWORD=15

# Per-platform default vendor selection (apify | brightdata | vetric | hikerapi).
# NOTE: superseded at runtime by the admin-editable routing config
# (app_config/routing, Finance → Provider routing). These remain a low-priority
# fallback only. IG keyword now defaults to hikerapi via the routing seed.
# Empty = let the first-supporting adapter handle the platform.
DEFAULT_VENDOR_INSTAGRAM=apify
DEFAULT_VENDOR_FACEBOOK=apify
DEFAULT_VENDOR_TIKTOK=apify

# Environment: development | production
ENVIRONMENT=development

# Dashboard server-side aggregation for PUBLIC SHARES (P2). ON by default.
# When true, the share endpoint computes each eligible widget server-side and,
# when the whole layout is covered, omits the raw posts array (payload becomes
# KB/widget, post-count-independent). Per-request `?agg=client` forces the legacy
# full-posts path for debugging; this var is the global kill switch. Any widget
# the engine can't reproduce keeps client-side aggregation, so it's safe on.
DASHBOARD_SERVER_AGG=true

# Signup / access gate: open | allowlist | entitlements
#   open          - any Firebase user passes (dev convenience; NO blocking).
#   allowlist     - only ALLOWED_EMAILS (or invited/org-member) emails may sign in.
#   entitlements  - anyone may sign in but `tier=blocked` users are 402'd on every
#                   data route -> redirected to /account-pending. Invitees are
#                   promoted to `trial` when they accept (see /orgs/join). This is
#                   the prod setting; set it here to test blocking locally.
SIGNUP_GATE=entitlements
# Super admins bypass the gate entirely (comma-separated).
SUPER_ADMIN_EMAILS=
# Only used when SIGNUP_GATE=allowlist (comma-separated).
ALLOWED_EMAILS=

# CORS - comma-separated allowed origins (add your production domain in prod)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (for billing redirects, etc.)
FRONTEND_URL=http://localhost:5173

# Worker service URL (Cloud Run worker URL in production)
# WORKER_SERVICE_URL=https://sl-worker-xxx-uc.a.run.app

# Google Search grounding for design_research tool
ENABLE_SEARCH_GROUNDING=true

# Vertex AI (set to true to use Vertex AI instead of Google AI Studio)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Sentry error tracking (backend - shared by api + worker). Leave DSN empty to
# disable (local dev default). Sample rates default to 0 = errors-only, which
# keeps the Sentry free plan from ever billing; raise to experiment with tracing.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
