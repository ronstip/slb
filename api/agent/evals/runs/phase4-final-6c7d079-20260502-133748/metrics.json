        {
          "tool": "execute_sql",
          "args": {
            "query": "SELECT ep.sentiment, COUNT(*) as count,\n  ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 1) as pct\nFROM `social-listening-pl.social_listening.enriched_posts` ep\nJOIN `social-listening-pl.social_listening.posts` p ON p.post_id = ep.post_id\nWHERE p.collection_id = 'eval-collection-1'\n  AND ep.is_related_to_task IS NOT FALSE\nGROUP BY ep.sentiment ORDER BY count DESC",
            "project_id": "social-listening-pl"
          },
          "first_turn": 0,
          "repeat_turn": 0
        },
        {
          "tool": "execute_sql",
          "args": {
            "project_id": "social-listening-pl",
            "query": "SELECT p.platform, ep.sentiment, COUNT(*) as count\nFROM `social-listening-pl.social_listening.posts` p\nJOIN `social-listening-pl.social_listening.enriched_posts` ep ON p.post_id = ep.post_id\nWHERE p.collection_id = 'eval-collection-1'\n  AND ep.is_related_to_task IS NOT FALSE\nGROUP BY p.platform, ep.sentiment"
          },
          "first_turn": 0,
          "repeat_turn": 0
        },
        {
          "tool": "execute_sql",
          "args": {
            "project_id": "social-listening-pl",
            "query": "WITH latest_eng AS (\n  SELECT post_id, likes, views\n  FROM `social-listening-pl.social_listening.post_engagements`\n  QUALIFY ROW_NUMBER() OVER (PARTITION BY post_id ORDER BY fetched_at DESC) = 1\n)\nSELECT ep.channel_type, COUNT(*) as posts,\n  SUM(COALESCE(le.likes, 0)) as total_likes,\n  SUM(COALESCE(le.views, 0)) as total_views\nFROM `social-listening-pl.social_listening.enriched_posts` ep\nJOIN `social-listening-pl.social_listening.posts` p ON p.post_id = ep.post_id\nLEFT JOIN latest_eng le ON p.post_id = le.post_id\nWHERE p.collection_id = 'eval-collection-1'\n  AND ep.is_related_to_task IS NOT FALSE\nGROUP BY ep.channel_type ORDER BY posts DESC"
          },
          "first_turn": 0,
          "repeat_turn": 0
