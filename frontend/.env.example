VITE_API_URL=http://localhost:8000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=social-listening-pl
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sentry error tracking (frontend). Leave DSN empty to disable (local dev
# default). Sample rates default to 0 = errors-only; raise to experiment with
# tracing/replay during the trial (keeps the free plan from billing at 0).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_SAMPLE_RATE=0

# Brand logos in dashboard tables (logo.dev). Publishable token (pk_...), safe
# to expose client-side. Get one free at https://logo.dev. Unset -> brands
# render as colored initial chips instead of logos.
VITE_LOGODEV_TOKEN=
