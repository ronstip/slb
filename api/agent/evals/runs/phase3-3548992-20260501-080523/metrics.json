      "duplicate_actions": [
        {
          "tool": "execute_sql",
          "args": {
            "project_id": "social-listening-pl",
            "query": "WITH theme_periods AS (\n  SELECT \n    theme,\n    CASE \n      WHEN DATE(p.posted_at) BETWEEN '2026-04-24' AND '2026-04-30' THEN 'current'\n      WHEN DATE(p.posted_at) BETWEEN '2026-04-17' AND '2026-04-23' THEN 'previous'\n    END as period,\n    COUNT(*) as post_count\n  FROM `social-listening-pl.social_listening.enriched_posts` ep, UNNEST(ep.themes) theme\n  JOIN `social-listening-pl.social_listening.posts` p ON p.post_id = ep.post_id\n  WHERE p.collection_id = 'eval-collection-1'\n    AND ep.is_related_to_task IS NOT FALSE\n    AND theme IN ('product complaints', 'user tutorials', 'competitor mentions')\n  GROUP BY 1, 2\n)\nSELECT \n  theme,\n  MAX(CASE WHEN period = 'previous' THEN post_count ELSE 0 END) as prev_week_posts,\n  MAX(CASE WHEN period = 'current' THEN post_count ELSE 0 END) as curr_week_posts,\n  ROUND(SAFE_DIVIDE(\n    MAX(CASE WHEN period = 'current' THEN post_count ELSE 0 END) - MAX(CASE WHEN period = 'previous' THEN post_count ELSE 0 END),\n    MAX(CASE WHEN period = 'previous' THEN post_count ELSE 0 END)\n  ) * 100, 1) as growth_pct\nFROM theme_periods\nWHERE period IS NOT NULL\nGROUP BY 1\nORDER BY growth_pct DESC"
          },
          "first_turn": 1,
          "repeat_turn": 1
        }
      ],
