# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/


# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code: share skills/agents/commands & shared settings, keep local overrides private
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/settings.json
.claude/settings.local.json

# Firebase cache
.firebase/

# GCP - ignore credential files but allow config files
service-account*.json
credentials*.json
*-key.json
*-credentials.json

# Allow essential JSON files
!package.json
!package-lock.json
!tsconfig.json
!config/*.json
!bigquery/**/*.json

# OS
.DS_Store
Thumbs.db

# Logs
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Frontend / Node.js
frontend/node_modules/
frontend/.vite/
frontend/dist/
frontend/.turbo/
frontend/.next/
frontend/out/
frontend/build/

# E2E tests
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/screenshots/

# Playwright MCP logs & screenshots
.playwright-mcp/
screenshots/
*.png
# ...but keep the social-card image used by Open Graph / Twitter meta tags.
!frontend/public/og-image.png

# Agent eval harness - keep reports + per-run metadata, drop bulk
api/agent/evals/runs/_debug/
api/agent/evals/runs/*.log
api/agent/evals/runs/**/transcripts/

